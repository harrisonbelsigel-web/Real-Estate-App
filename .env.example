# Database Configuration
# Default (local dev): a SQLite file, no server required.
DATABASE_URL=sqlite:///./real_estate_app.db
# For production, use PostgreSQL instead, e.g.:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/real_estate_app
SQL_ECHO=False

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API Configuration
DEBUG=False
